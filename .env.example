# ============================================================
# AI Content Publishing API — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_VERSION=v1

# --- Prisma (takes precedence over individual DB_* vars) ---
DATABASE_URL="postgresql://ai_content_user:supersecret@localhost:5432/ai_content_db?schema=content"

# --- Encryption (AES-256-GCM for tokens/keys at rest) ---
ENCRYPTION_SECRET=change_me_to_a_random_64_char_secret_never_commit_this

# --- Bcrypt (password hashing cost factor — minimum 12, increase for stronger servers) ---
BCRYPT_COST=12

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=ai_content_user
DB_PASSWORD=supersecret
DB_NAME=ai_content_db
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# --- Cache (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redissecret
REDIS_DB=0
REDIS_TTL_DEFAULT=3600

# --- Security ---
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log
